# =============================================================================
# Raybags Data Platform — environment template.
# Copy to `.env` for local/compose use. NEVER commit the real `.env`.
# The SAME variables drive local (SQLite) and prod (Supabase/Postgres);
# only DATABASE_URL changes between them.
# =============================================================================

# ---- meta ----
PROJECT_NAME="Raybags Data Platform"
ENVIRONMENT=local                 # local | test | staging | production
DEBUG=true

# ---- security (CHANGE in every non-local env) ----
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ---- database ----
# Local (zero-setup):
DATABASE_URL=sqlite+aiosqlite:///./portfolio.db
# Postgres (compose):  postgresql+asyncpg://raybags:raybags@postgres:5432/raybags
# Supabase (prod, pooled):  postgresql+asyncpg://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ---- bootstrap admin (seed) ----
FIRST_ADMIN_EMAIL=admin@raybags.com
FIRST_ADMIN_PASSWORD=ChangeMe!123
FIRST_ADMIN_NAME="Site Admin"

# ---- cors (comma-separated) ----
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- frontend ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---- infra (enabled per feature flag) ----
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ---- postgres container (compose) ----
POSTGRES_USER=raybags
POSTGRES_PASSWORD=raybags
POSTGRES_DB=raybags

# ---- object storage (S3 / MinIO) ----
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=raybags-platform
S3_REGION=eu-central-1

# ---- supabase (optional) ----
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---- AI ----
OPENAI_API_KEY=

# ---- monitoring ----
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# Nginx reverse proxy for the Raybags Data Platform.
#   /            -> Next.js frontend (the public face, raybags.com)
#   /api         -> FastAPI backend
#   /annotation  -> Data Annotation Platform (separate compose stack, port 5174)
#   /docs /redoc /openapi.json /metrics -> backend (API tooling)
# TLS is terminated by Cloudflare in front of this; add a 443 server block
# with certs when going direct.
# =============================================================================

upstream backend_api {
    server backend:8000;
}

upstream frontend_app {
    server frontend:3000;
}

# Annotation platform frontend — separate Docker compose stack on host port 5174.
# Requires extra_hosts: ["host.docker.internal:host-gateway"] on the nginx service.
upstream annotation_app {
    server host.docker.internal:5174;
}

# DataForge ELT — separate Docker compose stack on the same host.
upstream dataforge_api {
    server host.docker.internal:8002;
}

upstream dataforge_ui {
    server host.docker.internal:8503;
}

server {
    listen 80;
    server_name _;

    client_max_body_size 50m;

    # security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ---- DataForge ELT ----
    location /dataforge/api/ {
        proxy_pass http://dataforge_api;
        rewrite ^/dataforge(/api/.*)$ $1 break;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location /dataforge/ {
        proxy_pass http://dataforge_ui/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # ---- annotation platform ----
    # The annotation frontend nginx handles the /api/ sub-proxy internally.
    location /annotation {
        proxy_pass http://annotation_app;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 120s;
    }

    # ---- backend API ----
    location /api/ {
        proxy_pass http://backend_api;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location ~ ^/(docs|redoc|openapi.json|metrics)$ {
        proxy_pass http://backend_api;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ---- frontend (everything else) ----
    location / {
        proxy_pass http://frontend_app;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
